<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1E1E20">

    <!-- Custom Header Toolbar with Back and Tab selector -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#2B2D30"
        android:paddingStart="4dp"
        android:paddingEnd="12dp">

        <ImageView
            android:id="@+id/btnTutorialBack"
            android:layout_width="36dp"
            android:layout_height="match_parent"
            android:src="@drawable/ic_undo"
            android:rotation="180"
            android:padding="8dp"
            android:contentDescription="Back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/tvTutorialTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Урок"
            android:textColor="#DFE1E5"
            android:textSize="12sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end"
            android:layout_marginStart="4dp" />

        <!-- Tab Buttons (Theory / Practice) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:orientation="horizontal"
            android:background="#1E1E20"
            android:padding="2dp">

            <TextView
                android:id="@+id/tabTheory"
                android:layout_width="72dp"
                android:layout_height="match_parent"
                android:text="Теорія"
                android:textColor="#DFE1E5"
                android:textSize="11sp"
                android:gravity="center"
                android:background="#3574F0"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/tabPractice"
                android:layout_width="72dp"
                android:layout_height="match_parent"
                android:text="Практика"
                android:textColor="#808080"
                android:textSize="11sp"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>
    </LinearLayout>

    <!-- CONTENT CONTAINERS -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Theory WebView Container -->
        <WebView
            android:id="@+id/wvTheory"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#1E1E20" />

        <!-- Practice Playground Container (hidden by default) -->
        <LinearLayout
            android:id="@+id/layoutPractice"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Practice Toolbar (Reset / Run / Snippet Selector) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#2B2D30"
                android:paddingStart="8dp"
                android:paddingEnd="8dp">

                <TextView
                    android:id="@+id/btnResetCode"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:text="Скинути"
                    android:textColor="#DFE1E5"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:background="#3E4246"
                    android:clickable="true"
                    android:focusable="true" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/btnRunPlayground"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:text="▶ Запустити"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:background="#499C54"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- Code Editor -->
            <io.github.rosemoe.sora.widget.CodeEditor
                android:id="@+id/playgroundEditor"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="3" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#3E4246" />

            <!-- Console Title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="20dp"
                android:text="Консоль виводу"
                android:textColor="#808080"
                android:textSize="10sp"
                android:gravity="center_vertical"
                android:paddingStart="8dp"
                android:background="#2B2D30" />

            <!-- Console Output -->
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="#1E1E1E"
                android:padding="8dp">

                <TextView
                    android:id="@+id/playgroundConsole"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#A9B7C6"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />
            </ScrollView>

        </LinearLayout>
    </FrameLayout>
</LinearLayout>
