<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/drawerRoot"
    android:layout_width="260dp"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/idea_toolbar"
    android:layout_gravity="start">

    <!-- Drawer header -->
    <LinearLayout
        android:id="@+id/drawerHeader"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:background="@color/idea_bg"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvDrawerProjectLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/drawer_project_label"
            android:textColor="#5A8FBB"
            android:textSize="11sp"
            android:fontFamily="sans-serif"
            android:letterSpacing="0.08" />

    </LinearLayout>

    <!-- Project root row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvDrawerArrow"
            android:layout_width="16dp"
            android:layout_height="wrap_content"
            android:text="▼"
            android:textColor="#808080"
            android:textSize="9sp"
            android:gravity="center"
            android:layout_marginEnd="4dp" />

        <TextView
            android:id="@+id/tvDrawerMavenHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/drawer_maven_hint"
            android:textColor="#808080"
            android:textSize="11sp" />

    </LinearLayout>

    <!-- Separator -->
    <View
        android:id="@+id/drawerSeparator1"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/idea_separator" />

    <!-- File tree -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/fileTreeRecycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none" />

    <!-- Separator -->
    <View
        android:id="@+id/drawerSeparator2"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/idea_separator" />

    <!-- New File button -->
    <LinearLayout
        android:id="@+id/btnNewFile"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:gravity="center_vertical"
        android:background="?attr/selectableItemBackground">

        <TextView
            android:id="@+id/tvDrawerNewFilePlus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+"
            android:textColor="@color/idea_accent"
            android:textSize="18sp"
            android:layout_marginEnd="10dp" />

        <TextView
            android:id="@+id/tvDrawerNewFileText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/menu_new_java_file"
            android:textColor="@color/idea_text"
            android:textSize="13sp" />

    </LinearLayout>

    <!-- Import Files button -->
    <LinearLayout
        android:id="@+id/btnImportFiles"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:gravity="center_vertical"
        android:background="?attr/selectableItemBackground">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⇘"
            android:textColor="@color/idea_accent"
            android:textSize="18sp"
            android:layout_marginEnd="10dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/menu_import_files"
            android:textColor="@color/idea_text"
            android:textSize="13sp" />

    </LinearLayout>

</LinearLayout>
