<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- HEADING -->
    <TextView
        android:id="@+id/blockHeading"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:layout_marginBottom="4dp"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:fontFamily="sans-serif-medium"
        android:textSize="17sp"
        android:textColor="#A9B7C6"
        android:visibility="gone" />

    <!-- PARAGRAPH -->
    <TextView
        android:id="@+id/blockParagraph"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="6dp"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:textSize="14sp"
        android:lineSpacingMultiplier="1.25"
        android:textColor="#C9CEC9"
        android:visibility="gone" />

    <!-- CODE (моноширинний з підсвіткою) -->
    <HorizontalScrollView
        android:id="@+id/blockCodeScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="8dp"
        android:scrollbars="horizontal"
        android:fillViewport="false"
        android:visibility="gone">

        <TextView
            android:id="@+id/blockCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="10dp"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:lineSpacingMultiplier="1.15"
            android:textIsSelectable="true" />
    </HorizontalScrollView>

    <!-- LIST -->
    <TextView
        android:id="@+id/blockList"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:fontFamily="monospace"
        android:textSize="13sp"
        android:lineSpacingMultiplier="1.3"
        android:textColor="#C9CEC9"
        android:visibility="gone" />

    <!-- NOTE / WARNING (рамка) -->
    <LinearLayout
        android:id="@+id/blockNoteBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="10dp"
        android:orientation="horizontal"
        android:padding="10dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/blockNoteIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/blockNoteText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="13sp"
            android:lineSpacingMultiplier="1.25" />
    </LinearLayout>

    <!-- TABLE -->
    <TextView
        android:id="@+id/blockTable"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="14dp"
        android:layout_marginBottom="10dp"
        android:padding="8dp"
        android:fontFamily="monospace"
        android:textSize="12sp"
        android:lineSpacingMultiplier="1.3"
        android:visibility="gone" />
</LinearLayout>
