<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.JavaDroid.Fullscreen">
        <activity
            android:name=".WelcomeActivity"
            android:exported="true"
            android:screenOrientation="landscape"
            android:theme="@style/Theme.JavaDroid.Fullscreen">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="landscape"
            android:theme="@style/Theme.JavaDroid.Fullscreen" />

        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:label="@string/menu_settings"
            android:screenOrientation="landscape"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".GitActivity"
            android:exported="false"
            android:label="@string/git_activity_title"
            android:screenOrientation="landscape"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".LibraryManagerActivity"
            android:exported="false"
            android:label="@string/lib_title"
            android:screenOrientation="landscape"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".LearnActivity"
            android:exported="false"
            android:screenOrientation="landscape" />

        <activity
            android:name=".TutorialActivity"
            android:exported="false"
            android:screenOrientation="landscape" />

        <activity
            android:name=".learn.LessonActivity"
            android:exported="false"
            android:screenOrientation="landscape" />

        <activity
            android:name=".GlobalSearchActivity"
            android:exported="false"
            android:label="@string/menu_global_search"
            android:screenOrientation="landscape"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".MediaPlayerActivity"
            android:exported="false"
            android:label="@string/media_player_title"
            android:screenOrientation="landscape"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".AiChatActivity"
            android:exported="false"
            android:label="@string/ai_title"
            android:screenOrientation="landscape"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".BytecodeEditorActivity"
            android:exported="false"
            android:label="Bytecode Editor"
            android:screenOrientation="landscape"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".ClassBrowserActivity"
            android:exported="false"
            android:label="@string/class_browser_title"
            android:screenOrientation="landscape"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".SvgViewerActivity"
            android:exported="false"
            android:label="SVG Viewer"
            android:screenOrientation="landscape"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".ImageViewerActivity"
            android:exported="false"
            android:label="Image Viewer"
            android:screenOrientation="landscape"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".CallGraphActivity"
            android:exported="false"
            android:label="Call Graph"
            android:screenOrientation="landscape"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".DatabaseInspectorActivity"
            android:exported="false"
            android:label="Database Inspector"
            android:screenOrientation="landscape"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".HttpApiClientActivity"
            android:exported="false"
            android:label="HTTP Client"
            android:screenOrientation="landscape"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".WebViewPreviewActivity"
            android:exported="false"
            android:label="WebView Preview"
            android:screenOrientation="landscape"
            android:parentActivityName=".MainActivity" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="com.ccs.javadroid.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/provider_paths" />
        </provider>
    </application>

</manifest>
